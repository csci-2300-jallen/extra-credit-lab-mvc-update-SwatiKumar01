{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch app",
      "type": "cppdbg",
      "request": "launch",
      "program": "${command:cmake.launchTargetPath}",
      "cwd": "${workspaceFolder}",
      "args": [],
      "stopAtEntry": false,
      "externalConsole": false,
      "console": "integratedTerminal",
      "preLaunchTask": "CMake: build",

      "osx": {
        "type": "cppdbg",
        "MIMode": "lldb",
        "environment": [
          {
            "name": "DYLD_FRAMEWORK_PATH",
            "value": "${config:cmake.configureSettings.Qt6_ROOT}/lib"
          }
        ]
      },

      "linux": {
        "type": "cppdbg",
        "MIMode": "gdb"
      },

      "windows": {
        "type": "cppvsdbg",
        "environment": [
          {
            "name": "PATH",
            "value": "${env:PATH};${config:cmake.configureSettings.Qt6_ROOT}/bin"
          }
        ]
      }
    }
  ]
}